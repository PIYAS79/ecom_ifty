generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Entities 

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  photo     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Enums
enum Role {
  USER
  ADMIN
}
